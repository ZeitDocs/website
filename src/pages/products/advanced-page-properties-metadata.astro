---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { withBase } from '../../utils/paths';
---

<SiteLayout
  title="Advanced Page Properties & Metadata | Zeitdocs"
  description="Advanced Page Properties & Metadata — coming soon to Zeitdocs."
>
  <section class="hero">
    <div class="section-inner">
      <div class="product-hero-kicker">
        <img
          class="product-hero-logo"
          src={withBase('/assets/products/advanced-page-properties-metadata-logo.png')}
          alt=""
          width="389"
          height="402"
          decoding="async"
        />
        <span class="eyebrow">Coming soon</span>
      </div>
      <h1>Advanced Page Properties & Metadata</h1>
      <p class="lead">
        Enhanced page properties and structured metadata for Confluence. This app is
        coming soon — full documentation will follow at launch.
      </p>
    </div>
  </section>
</SiteLayout>

<style>
  .product-hero-kicker {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .product-hero-logo {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: contain;
  }

  @media (max-width: 560px) {
    .product-hero-logo {
      width: 60px;
      height: 60px;
    }
  }
</style>
