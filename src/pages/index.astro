---
import FeatureCard from '../components/FeatureCard.astro';
import HeroIllustration from '../components/HeroIllustration.astro';
import ProductCard from '../components/ProductCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { withBase } from '../utils/paths';
---

<SiteLayout
  title="Zeitdocs | Documentation governance apps for Confluence"
  description="Zeitdocs builds clear, governance-oriented apps for Atlassian Confluence documentation teams."
>
  <section class="hero">
    <div class="section-inner hero-grid">
      <div>
        <span class="eyebrow">Confluence governance</span>
        <h1>Clearer control for serious documentation work.</h1>
        <p class="lead">
          Zeitdocs builds practical Confluence apps for teams that need visible classification,
          structured documentation governance and clearer guidance for sensitive content.
        </p>
        <div class="cta-row">
          <a class="button button-primary" href={withBase('/products/')}>View products</a>
          <a class="button button-secondary" href={withBase('/products/classify/')}>View Classify</a>
        </div>
      </div>
      <HeroIllustration />
    </div>
  </section>

  <section class="section band">
    <div class="section-inner">
      <div class="section-heading">
        <span class="eyebrow">Products</span>
        <h2>Apps for visible, maintainable Confluence governance.</h2>
        <p>
          The first product area is Classify, with documentation focused on visual
          classification banners, page header styles and permission guidance.
        </p>
      </div>
      <div class="card-grid">
        <ProductCard
          name="Classify"
          description="Page Permissions & Visual Security Banners"
          detail="Visually classify Confluence pages and help teams understand how sensitive content should be handled."
          href="/products/classify/"
          docsHref="/docs/classify/"
          variant="classify"
          logoSrc="/assets/products/classify-logo.png"
        />
        <ProductCard
          name="Sync My Page - Copy Publish"
          description="Copy, publish or synchronize Confluence pages."
          detail="Coming soon. Controlled page reuse and publishing flows for Confluence."
          href="/products/sync-my-page-copy-publish/"
          status="Coming soon"
          variant="sync"
          logoSrc="/assets/products/sync-my-page-copy-publish-logo.png"
        />
        <ProductCard
          name="Advanced Page Properties & Metadata"
          description="Structured metadata for Confluence documentation."
          detail="Coming soon. Stronger page property and metadata workflows for Confluence."
          href="/products/advanced-page-properties-metadata/"
          status="Coming soon"
          variant="metadata"
          logoSrc="/assets/products/advanced-page-properties-metadata-logo.png"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="section-heading">
        <span class="eyebrow">Why Zeitdocs</span>
        <h2>Documentation-first, admin-oriented and calm by design.</h2>
      </div>
      <div class="feature-grid">
        <FeatureCard
          title="Built for Confluence admins"
          text="Zeitdocs products explain governance through settings, page behavior and clear documentation instead of vague claims."
        />
        <FeatureCard
          title="Visible guidance for readers"
          text="Classify makes sensitivity visible in the page experience so readers can understand how content should be handled."
          accent="orange"
        />
        <FeatureCard
          title="Structured product documentation"
          text="The documentation area is organized around common admin tasks, page editor tasks and practical use cases."
        />
        <FeatureCard
          title="Conservative product claims"
          text="The site avoids unsupported security promises and clearly separates classification guidance from permissions."
          accent="orange"
        />
      </div>
    </div>
  </section>
</SiteLayout>
