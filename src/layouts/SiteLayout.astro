---
import LogoMark from '../components/LogoMark.astro';
import { withBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath ?? pathname, Astro.site ?? Astro.url).href;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/products/', label: 'Products' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

const isCurrent = (href: string) =>
  href === '/' ? pathname === withBase('/') : pathname === withBase(href) || pathname.startsWith(withBase(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/assets/brand/no-background-zeitdocs.png')} type="image/png" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand-link" href={withBase('/')} aria-label="Zeitdocs home">
            <LogoMark />
            <span class="brand-name">Zeitdocs</span>
          </a>
          <nav class="site-nav" aria-label="Main navigation">
            {
              navItems.map((item) => (
                <a href={withBase(item.href)} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </header>
      <main class="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="section-inner site-footer__inner">
          <span>&copy; {new Date().getFullYear()} Zeitdocs</span>
          <nav class="footer-legal-links" aria-label="Legal and trust links">
            <a href={withBase('/privacy/')}>Privacy Policy</a>
            <span aria-hidden="true">&middot;</span>
            <a href={withBase('/terms/')}>Terms of Use</a>
            <span aria-hidden="true">&middot;</span>
            <a href={withBase('/security/')}>Security</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
