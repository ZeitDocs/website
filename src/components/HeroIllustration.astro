---
import { Image } from 'astro:assets';
import heroZeit from '../assets/images/zeitdocs-hero-zeit.png';

interface Props {
  label?: string;
}

const {
  label = 'Abstract representation of documentation evolving through time while remaining structured and governed',
} = Astro.props;
---

<figure class="hero-illustration">
  <Image
    src={heroZeit}
    alt={label}
    width={1408}
    height={768}
    loading="eager"
    fetchpriority="high"
    decoding="async"
    sizes="(max-width: 900px) calc(100vw - 32px), 660px"
    class="hero-illustration__image"
  />
</figure>

<style>
  .hero-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(52vw, 680px);
    min-width: 0;
    max-width: 100%;
    margin: 0;
    justify-self: end;
    overflow: visible;
  }

  :global(.hero-illustration__image) {
    display: block;
    width: 100%;
    max-width: 680px;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
    -webkit-mask-image: radial-gradient(ellipse 98% 94% at 50% 50%, #000 82%, transparent 100%);
    mask-image: radial-gradient(ellipse 98% 94% at 50% 50%, #000 82%, transparent 100%);
  }

  @media (min-width: 901px) {
    .hero-illustration {
      transform: translateX(28px);
    }
  }

  @media (max-width: 900px) {
    .hero-illustration {
      width: 100%;
      margin-top: 8px;
      justify-self: stretch;
      overflow: hidden;
      transform: none;
    }

    :global(.hero-illustration__image) {
      max-width: none;
      object-fit: contain;
    }
  }
</style>
