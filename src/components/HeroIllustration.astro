---
interface Props {
  label?: string;
}

const { label = 'Classified page illustration' } = Astro.props;
---

<figure class="hero-illustration" aria-label={label}>
  <div class="panel panel--back"></div>
  <div class="panel panel--main">
    <div class="panel__header">
      <span></span>
      <strong>Confidential</strong>
    </div>
    <div class="panel__line panel__line--wide"></div>
    <div class="panel__line"></div>
    <div class="panel__line panel__line--short"></div>
    <div class="metadata-grid">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
  <div class="control-card">
    <span class="control-card__dot"></span>
    <div>
      <strong>Permission guidance</strong>
      <span>Review access before sharing.</span>
    </div>
  </div>
</figure>

<style>
  .hero-illustration {
    position: relative;
    min-height: 420px;
    margin: 0;
  }

  .panel {
    position: absolute;
    border: var(--zd-border);
    border-radius: var(--zd-radius-lg);
    background: var(--zd-white);
    box-shadow: var(--zd-shadow-soft);
  }

  .panel--back {
    inset: 42px 28px 40px 80px;
    background:
      linear-gradient(90deg, rgba(215, 238, 246, 0.55) 0 26%, transparent 26%),
      var(--zd-white);
    transform: rotate(4deg);
  }

  .panel--main {
    inset: 8px 64px 78px 20px;
    padding: 26px;
  }

  .panel__header {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--zd-orange-100);
    border-radius: var(--zd-radius-md);
    background: var(--zd-orange-50);
    color: var(--zd-orange-700);
    padding: 14px;
  }

  .panel__header span {
    width: 32px;
    height: 32px;
    border: 2px solid var(--zd-orange-500);
    border-radius: 10px;
    background: var(--zd-white);
  }

  .panel__line {
    height: 10px;
    margin-top: 22px;
    border-radius: 999px;
    background: var(--zd-gray-100);
  }

  .panel__line--wide {
    width: 86%;
  }

  .panel__line:not(.panel__line--wide) {
    width: 72%;
  }

  .panel__line--short {
    width: 46%;
  }

  .metadata-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 30px;
  }

  .metadata-grid span {
    height: 58px;
    border: 1px solid var(--zd-blue-100);
    border-radius: var(--zd-radius-sm);
    background: var(--zd-blue-50);
  }

  .control-card {
    position: absolute;
    right: 0;
    bottom: 12px;
    display: flex;
    width: min(280px, 72%);
    gap: 14px;
    border: var(--zd-border);
    border-radius: var(--zd-radius-md);
    background: var(--zd-white);
    box-shadow: var(--zd-shadow-soft);
    padding: 18px;
  }

  .control-card__dot {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
    margin-top: 3px;
    border-radius: 50%;
    background: var(--zd-blue-300);
    box-shadow: 0 0 0 6px var(--zd-blue-50);
  }

  .control-card strong,
  .control-card span {
    display: block;
  }

  .control-card span {
    margin-top: 4px;
    color: var(--zd-gray-700);
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .hero-illustration {
      min-height: 360px;
    }
  }
</style>
